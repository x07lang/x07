{
  :kind entry
  :module_id main
  :schema_version x07.x07ast@0.8.0
  :imports (std.bytes std.fmt std.vec)
  :decls ()
  :solve (begin
    (let n (bytes.len input))
    (let v (std.vec.with_capacity (+ n n)))
    (let cur 0)
    (let count 0)
    (for i 0 n
      (begin
        (let c (std.bytes.get_u8 input i))
        (if
          (= i 0)
          (begin (set0 cur c) (set0 count 1))
          (if
            (= c cur)
            (set0 count (+ count 1))
            (begin
              (set0 v (std.vec.push v cur))
              (let d (std.fmt.u32_to_dec count))
              (set0 v (std.vec.extend_bytes v (bytes.view d)))
              (set0 cur c)
              (set0 count 1)
            )
          )
        )
      )
    )
    (if
      (> n 0)
      (begin
        (set0 v (std.vec.push v cur))
        (let d2 (std.fmt.u32_to_dec count))
        (set0 v (std.vec.extend_bytes v (bytes.view d2)))
      )
      0
    )
    (std.vec.as_bytes v)
  )
}
