{
  :kind entry
  :module_id main
  :schema_version x07.x07ast@0.8.0
  :imports (std.bytes std.text.ascii std.text.slices std.vec)
  :decls ()
  :solve (begin
    (let n (bytes.len input))
    (if (= n 0) (return (bytes.lit "")) 0)
    (let sl (std.text.ascii.split_lines_view input))
    (let k (std.text.slices.count_v1 (bytes.view sl)))
    (let v (std.vec.with_capacity (+ n 1)))
    (for i 0 k
      (begin
        (set0 v (std.vec.extend_bytes v (std.text.slices.view_at_v1 input (bytes.view sl) (- (- k 1) i))))
        (set0 v (std.vec.push v 10))
      )
    )
    (std.vec.as_bytes v)
  )
}
