{
  :kind entry
  :module_id main
  :schema_version x07.x07ast@0.8.0
  :imports (std.bytes std.fmt std.parse std.text.ascii std.text.slices)
  :decls ()
  :solve (begin
    (let n (bytes.len input))
    (if (= n 0) (return (bytes.lit "0")) 0)
    (let sl (std.text.ascii.split_lines_view input))
    (let k (std.text.slices.count_v1 (bytes.view sl)))
    (let total 0)
    (for i 0 k
      (begin
        (let w (std.text.slices.view_at_v1 input (bytes.view sl) i))
        (if (> (view.len w) 0)
          (begin
            (let comma (std.bytes.find_u8 w 44))
            (set0 total (+ total (std.parse.u32_dec_at w (+ comma 1))))
          )
          0
        )
      )
    )
    (std.fmt.u32_to_dec total)
  )
}
