{
  :kind entry
  :module_id main
  :schema_version x07.x07ast@0.8.0
  :imports (std.bytes std.fmt std.small_map std.text.ascii std.text.slices)
  :decls ()
  :solve (begin
    (let toks (std.text.ascii.tokenize_words_lower input))
    (let sl (std.text.ascii.split_u8 (bytes.view toks) 32))
    (let k (std.text.slices.count_v1 (bytes.view sl)))
    (let m (std.small_map.empty_bytes_u32))
    (for i 0 k
      (set0 m
        (std.small_map.inc1_bytes_u32 m
          (std.text.slices.view_at_v1 (bytes.view toks) (bytes.view sl) i)
        )
      )
    )
    (let best (bytes.lit ""))
    (let best_count 0)
    (for i 0 k
      (begin
        (let w (std.text.slices.view_at_v1 (bytes.view toks) (bytes.view sl) i))
        (let c (std.small_map.get_bytes_u32_or (bytes.view m) w 0))
        (if
          (||
            (> c best_count)
            (&&
              (= c best_count)
              (<
                (std.bytes.cmp_range w 0
                  (view.len w)
                  (bytes.view best)
                  0
                  (bytes.len best)
                )
                0
              )
            )
          )
          (begin (set0 best_count c) (set0 best (view.to_bytes w)))
          0
        )
      )
    )
    (bytes.concat
      (bytes.concat best (bytes.lit " "))
      (std.fmt.u32_to_dec best_count)
    )
  )
}
